<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Order ID and Date -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORD-1001"
                android:textColor="#3E4D44"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro" />

            <TextView
                android:id="@+id/tv_order_date_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="05/06/2026 - 08:30"
                android:textColor="#95A192"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro" />

        </RelativeLayout>

        <!-- Branch / Store Name -->
        <TextView
            android:id="@+id/tv_order_store"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Cơ sở 1 - Nguyễn Thị Minh Khai"
            android:textColor="#677559"
            android:textSize="12sp"
            android:textStyle="italic"
            android:fontFamily="@font/be_vietnam_pro" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E8DA"
            android:layout_marginTop="10dp" />

        <!-- Middle Section: Product info -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <ImageView
                android:id="@+id/img_product"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:src="@drawable/nuoc_sen_hau_giang" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/img_product"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_product_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nước tẩy trang sen Hậu Giang 500ml"
                    android:textColor="#3E4D44"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/be_vietnam_pro" />

                <TextView
                    android:id="@+id/tv_product_qty_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Số lượng: 15  x  309.000đ"
                    android:textColor="#7E8A83"
                    android:textSize="12sp"
                    android:fontFamily="@font/be_vietnam_pro" />
            </LinearLayout>

        </RelativeLayout>

        <!-- More items text -->
        <TextView
            android:id="@+id/tv_more_items"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="+ 2 sản phẩm khác"
            android:textColor="#677559"
            android:textSize="12sp"
            android:visibility="gone"
            android:fontFamily="@font/be_vietnam_pro" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E8DA"
            android:layout_marginTop="10dp" />

        <!-- Bottom Row: Price & Status & Actions -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tổng tiền"
                    android:textColor="#95A192"
                    android:textSize="11sp"
                    android:fontFamily="@font/be_vietnam_pro" />

                <TextView
                    android:id="@+id/tv_total_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="4.665.000đ"
                    android:textColor="#4F6544"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/be_vietnam_pro" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_nav_pill"
                android:backgroundTint="#FFEED6"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Chờ xử lý"
                android:textColor="#FF9F1C"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro" />

        </RelativeLayout>

        <!-- Action Buttons Layout -->
        <LinearLayout
            android:id="@+id/ll_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="end">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_nav_pill"
                android:backgroundTint="#FADBD8"
                android:text="Hủy"
                android:textColor="#E74C3C"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:fontFamily="@font/be_vietnam_pro"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_action"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_nav_pill"
                android:backgroundTint="#4F6544"
                android:text="Xác nhận"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:fontFamily="@font/be_vietnam_pro" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
