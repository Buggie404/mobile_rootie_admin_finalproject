<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="16dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:background="@drawable/bg_rounded_white_card"
    android:padding="16dp">

    <!-- Top Row: Checkbox, Order ID, Status Badge -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/img_select_order"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_radio_primary_unchecked"
            android:contentDescription="Chọn đơn hàng" />

        <TextView
            android:id="@+id/txt_order_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/img_select_order"
            android:layout_marginStart="8dp"
            android:layout_centerVertical="true"
            android:text="ORD-123456"
            android:textColor="#3E4D44"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

        <TextView
            android:id="@+id/txt_order_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_nav_pill"
            android:backgroundTint="#F2F3EC"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Chờ xác nhận"
            android:textColor="#7E8A83"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />
    </RelativeLayout>

    <!-- Content Rows: Customer, Date/Time, Items count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <!-- Customer Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_customer"
                app:tint="#677559"
                android:contentDescription="Khách hàng" />

            <TextView
                android:id="@+id/txt_customer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Bảo Nguyên"
                android:textColor="#677559"
                android:textSize="14sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>

        <!-- Date/Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_clock"
                app:tint="#677559"
                android:contentDescription="Thời gian" />

            <TextView
                android:id="@+id/txt_order_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Hôm nay, 08:15 AM"
                android:textColor="#677559"
                android:textSize="14sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>

        <!-- Items Count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_bag"
                app:tint="#677559"
                android:contentDescription="Sản phẩm" />

            <TextView
                android:id="@+id/txt_items_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="1 sản phẩm"
                android:textColor="#677559"
                android:textSize="14sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>

    </LinearLayout>

    <!-- Divider Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E8DA"
        android:layout_marginBottom="12dp" />

    <!-- Total section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Tổng cộng"
            android:textColor="#3E4D44"
            android:textSize="16sp"
            android:fontFamily="@font/be_vietnam_pro" />

        <TextView
            android:id="@+id/txt_order_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="241.000đ"
            android:textColor="#3E4D44"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />
    </RelativeLayout>

    <!-- Action Buttons Row -->
    <LinearLayout
        android:id="@+id/layout_order_actions"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btn_cancel_order"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_order_btn_outline"
            app:backgroundTint="@null"
            android:text="Hủy đơn"
            android:textColor="#3E4D44"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

        <Button
            android:id="@+id/btn_approve_order"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_order_btn_solid"
            app:backgroundTint="@null"
            android:text="Xác nhận"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

    </LinearLayout>

</LinearLayout>
