<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FEFBF4">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingBottom="48dp">

            <!-- Logo -->
            <ImageView
                android:id="@+id/img_logo"
                android:layout_width="260dp"
                android:layout_height="105dp"
                android:layout_marginTop="72dp"
                android:src="@drawable/imv_logo_text"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter" />

            <!-- Title: Đăng nhập Admin -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Đăng nhập Admin"
                android:textColor="#3E4D44"
                android:textSize="25sp"
                android:textStyle="normal"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Chào mừng bạn quay trở lại !"
                android:textColor="#3E4D44"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Email hoặc SĐT Input -->
            <EditText
                android:id="@+id/edt_username"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="9dp"
                android:background="@drawable/bg_login_input"
                android:hint="Email hoặc số điện thoại"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="#3E4D44"
                android:textColorHint="#95A192"
                android:textSize="13sp"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Mật khẩu Input Layout -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="9dp">

                <EditText
                    android:id="@+id/edt_password"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:hint="Mật khẩu"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="44dp"
                    android:textColor="#3E4D44"
                    android:textColorHint="#95A192"
                    android:textSize="13sp"
                    android:fontFamily="@font/be_vietnam_pro" />

                <ImageView
                    android:id="@+id/img_toggle_password"
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_eye_off"
                    app:tint="#3E4D44"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless" />
            </RelativeLayout>

            <!-- Quên mật khẩu? -->
            <TextView
                android:id="@+id/tv_forgot_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="9dp"
                android:text="Quên mật khẩu?"
                android:textColor="#3E4D44"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="end"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Đăng nhập Button -->
            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="9dp"
                android:background="@drawable/bg_login_button"
                app:backgroundTint="@null"
                android:text="Đăng nhập"
                android:textColor="#FEFBF4"
                android:textSize="13sp"
                android:textStyle="normal"
                android:textAllCaps="false"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Divider Line -->
            <View
                android:id="@+id/view_divider"
                android:layout_width="59dp"
                android:layout_height="2dp"
                android:layout_marginTop="16dp"
                android:background="#3E4D44" />

            <!-- Hoặc đăng nhập với -->
            <TextView
                android:id="@+id/tv_or_login_with"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Hoặc đăng nhập với"
                android:textColor="#3E4D44"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Google Circular Button -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_google"
                android:layout_width="39dp"
                android:layout_height="39dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="19.5dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_google" />
            </androidx.cardview.widget.CardView>

            <!-- Quick Profiles Section -->
            <TextView
                android:id="@+id/tv_test_profiles_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Đăng nhập nhanh (Kiểm thử)"
                android:textColor="#677559"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro" />

            <LinearLayout
                android:id="@+id/layout_test_profiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Admin Profile Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_profile_admin"
                    android:layout_width="80dp"
                    android:layout_height="64dp"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#FBF6ED">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_friends_filled"
                            app:tint="#3E4D44" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Admin"
                            android:textColor="#3E4D44"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/be_vietnam_pro" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Staff 1 Profile Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_profile_staff1"
                    android:layout_width="80dp"
                    android:layout_height="64dp"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#FBF6ED">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_friends"
                            app:tint="#3E4D44" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Staff 1"
                            android:textColor="#3E4D44"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/be_vietnam_pro" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Staff 5 Profile Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_profile_staff5"
                    android:layout_width="80dp"
                    android:layout_height="64dp"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#FBF6ED">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_friends"
                            app:tint="#3E4D44" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Staff 5"
                            android:textColor="#3E4D44"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/be_vietnam_pro" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Bottom footer link -->
            <TextView
                android:id="@+id/tv_footer_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:text="Chưa có tài khoản Admin? Liên hệ quản trị viên"
                android:textColor="#3E4D44"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
