<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_confirm"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Chi tiết sản phẩm"
            android:textColor="@color/rootie_green_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnCloseDialog"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_dialog_close_circle"
            android:clickable="true"
            android:contentDescription="Đóng"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_close"
            app:tint="@color/rootie_green_dark" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imvProduct"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@color/gray_light"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedSquareImageView" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHiddenBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stock_low"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Đang ẩn"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/be_vietnam_pro"
                android:maxLines="2"
                android:textColor="@color/rootie_green_dark"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvProductPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:textColor="#C62828"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProductOriginalPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:textColor="@color/gray_dark"
                    android:textSize="11sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layoutTags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvProductRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tag_pill"
            android:fontFamily="@font/be_vietnam_pro"
            android:paddingHorizontal="7dp"
            android:paddingVertical="3dp"
            android:textColor="@color/rootie_green_dark"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProductSold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_tag_pill"
            android:fontFamily="@font/be_vietnam_pro"
            android:paddingHorizontal="7dp"
            android:paddingVertical="3dp"
            android:textColor="@color/rootie_green_dark"
            android:textSize="10sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/badgeStock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_stock_normal"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="7dp"
            android:paddingVertical="3dp">

            <ImageView
                android:id="@+id/imvStockIcon"
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:contentDescription="Kho"
                android:src="@drawable/ic_warehouse"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvProductStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvProductSku"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/be_vietnam_pro"
        android:textColor="@color/gray_dark"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvProductBrand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/be_vietnam_pro"
        android:textColor="@color/gray_dark"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvProductSuitableFor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:fontFamily="@font/be_vietnam_pro"
        android:maxLines="1"
        android:textColor="@color/gray_dark"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvProductOrigin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/be_vietnam_pro"
        android:textColor="@color/gray_dark"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvProductDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:fontFamily="@font/be_vietnam_pro"
        android:lineSpacingExtra="2dp"
        android:maxLines="2"
        android:textColor="@color/gray_dark"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_see_all_outline"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/be_vietnam_pro"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:text="Đóng"
            android:textColor="@color/secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_order_btn_solid"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/be_vietnam_pro"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:text="Chỉnh sửa"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
