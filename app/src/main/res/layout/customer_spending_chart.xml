<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FEFBF4">

    <!-- 1. Header Toolbar -->
    <RelativeLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FEFBF4"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#3E4D44" />

        <TextView
            android:id="@+id/txt_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Phân tích chi tiêu"
            android:textColor="#3E4D44"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

    </RelativeLayout>

    <View
        android:id="@+id/header_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E8DA"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header_divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp">

            <!-- 2. Tabs HorizontalScrollView -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tab_week"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tuần này"
                        android:textColor="#3E4D44"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:background="@drawable/bg_search_bar"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tab_month"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tháng này"
                        android:textColor="#3E4D44"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:background="@drawable/bg_search_bar"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tab_3months"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 tháng"
                        android:textColor="#3E4D44"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:background="@drawable/bg_search_bar"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tab_6months"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6 tháng"
                        android:textColor="#3E4D44"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:background="@drawable/bg_search_bar"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tab_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Năm nay"
                        android:textColor="#3E4D44"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:background="@drawable/bg_search_bar"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- 3. Spending Overview Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E5E8DA">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng chi tiêu trong kỳ"
                            android:textColor="#7E8A83"
                            android:textSize="14sp"
                            android:fontFamily="@font/be_vietnam_pro" />

                        <!-- Large spending total with trend -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:id="@+id/txt_period_spending"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="42.850.000đ"
                                android:textColor="#3E4D44"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/be_vietnam_pro"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true" />

                            <TextView
                                android:id="@+id/txt_spending_trend_detail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/txt_period_spending"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="8dp"
                                android:text="↑15% so với năm trước"
                                android:textColor="#388E3C"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/be_vietnam_pro" />

                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F0F2EA"
                            android:layout_marginBottom="16dp"/>

                        <!-- Two Stats: Average and Highest -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Average card -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/bg_spending_card"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:id="@+id/txt_avg_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Trung bình/tháng"
                                    android:textColor="#7E8A83"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/be_vietnam_pro" />

                                <TextView
                                    android:id="@+id/txt_avg_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="3.570k"
                                    android:textColor="#3E4D44"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:fontFamily="@font/be_vietnam_pro"
                                    android:layout_marginTop="6dp" />

                            </LinearLayout>

                            <!-- Highest card -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/bg_spending_card"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Cao nhất"
                                    android:textColor="#7E8A83"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/be_vietnam_pro" />

                                <TextView
                                    android:id="@+id/txt_highest_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5.200k"
                                    android:textColor="#3E4D44"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:fontFamily="@font/be_vietnam_pro"
                                    android:layout_marginTop="6dp" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Total spending of all time (User requirement) -->
                        <TextView
                            android:id="@+id/txt_all_time_spending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng chi tiêu tích lũy: 120.000.000đ"
                            android:textColor="#7E8A83"
                            android:textSize="13sp"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:layout_marginTop="16dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </androidx.cardview.widget.CardView>

            <!-- 4. Spending Trend Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E5E8DA">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Xu hướng chi tiêu"
                            android:textColor="#3E4D44"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:layout_marginBottom="16dp" />

                        <!-- Sparkline chart -->
                        <com.veganbeauty.admin.features.home.views.SparklineView
                            android:id="@+id/sparkline_chart"
                            android:layout_width="match_parent"
                            android:layout_height="180dp" />

                        <!-- X Axis Labels Row -->
                        <LinearLayout
                            android:id="@+id/x_axis_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </androidx.cardview.widget.CardView>

            <!-- 5. đề xuất quản lý section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đề xuất quản lý"
                android:textColor="#3E4D44"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro"
                android:layout_marginBottom="12dp" />

            <!-- Bulb Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_white_card"
                android:backgroundTint="#334139"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- Lightbulb icon -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    app:tint="#FFFFFF"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiết kiệm hơn 20%"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro" />

                    <TextView
                        android:id="@+id/txt_advice_content"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bạn đã chi tiêu nhiều hơn cho tháng này. Hãy cân nhắc các gói ưu đãi combo để tối ưu hóa ngân sách."
                        android:textColor="#B3C4B8"
                        android:textSize="13sp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:layout_marginTop="4dp"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Row of 2 info badges -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Down trend -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_rounded_white_card"
                    android:backgroundTint="#E5E8DA"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chart"
                        app:tint="#4F6544"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xu hướng giảm"
                        android:textColor="#4F6544"
                        android:textSize="12sp"
                        android:fontFamily="@font/be_vietnam_pro" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-5% Tinh chất"
                        android:textColor="#3E4D44"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Membership level -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_rounded_white_card"
                    android:backgroundTint="#F0F2EA"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginStart="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_customer"
                        app:tint="#677559"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hạng thành viên"
                        android:textColor="#677559"
                        android:textSize="12sp"
                        android:fontFamily="@font/be_vietnam_pro" />

                    <TextView
                        android:id="@+id/txt_member_tier_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VIP"
                        android:textColor="#3E4D44"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
