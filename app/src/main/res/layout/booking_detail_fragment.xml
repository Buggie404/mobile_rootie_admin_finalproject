<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <RelativeLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="1dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#3E4D44" />

        <TextView
            android:id="@+id/txt_booking_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_toEndOf="@id/btn_back"
            android:ellipsize="end"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:singleLine="true"
            android:text="Chi tiết lịch đặt"
            android:textColor="#3E4D44"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txt_service_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Soi da chuyên sâu"
                    android:textColor="#3E4D44"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_status_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_nav_pill"
                    android:backgroundTint="#E8F8F5"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Hoàn tất"
                    android:textColor="#2ECC71"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_booking_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Thứ Năm, ngày 20 Tháng 6"
                    android:textColor="#59AE7B"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_booking_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="14:00 - 14:45 (45 phút)"
                    android:textColor="#4F6544"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txt_store_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Cửa hàng Rootie - địa chỉ"
                    android:textColor="#7E8A83"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txt_consultant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Chuyên viên: Linh"
                    android:textColor="#677559"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F2F4EB"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Thông tin khách hàng"
                android:textColor="#7E8A83"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txt_customer_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Nguyễn Khánh Xuân"
                    android:textColor="#3E4D44"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_customer_contact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="SĐT: 0912345678 | Email: xuannk@gmail.com"
                    android:textColor="#7E8A83"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txt_booking_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Ghi chú: ..."
                    android:textColor="#C0392B"
                    android:textSize="13sp"
                    android:textStyle="italic"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/txt_cancel_reason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Lý do hủy: ..."
                    android:textColor="#E74C3C"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/txt_feedback_section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FEF7ED"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Phản hồi khách hàng"
                android:textColor="#7E8A83"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layout_customer_feedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txt_feedback_stars"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="★★★★★"
                        android:textColor="#F5A623"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/txt_feedback_score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="5/5"
                        android:textColor="#3E4D44"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txt_feedback_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:lineSpacingExtra="4sp"
                    android:text="Nội dung phản hồi"
                    android:textColor="#3E4D44"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Ảnh phản hồi"
                    android:textColor="#7E8A83"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layout_feedback_images"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/txt_feedback_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Đánh giá ngày 19/06/2026"
                    android:textColor="#7E8A83"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/txt_feedback_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Khách chưa phản hồi lịch này."
                    android:textColor="#7E8A83"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
