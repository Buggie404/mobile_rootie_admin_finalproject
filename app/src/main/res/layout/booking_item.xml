<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Service Name & Time -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_booking_service"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/tv_booking_time"
                android:layout_marginEnd="8dp"
                android:text="Soi da cơ bản"
                android:textColor="#3E4D44"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro" />

            <TextView
                android:id="@+id/tv_booking_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="10:00 - 10:45"
                android:textColor="#4F6544"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro"
                android:drawableStart="@drawable/ic_history"
                android:drawablePadding="6dp"
                app:drawableTint="#4F6544" />

        </RelativeLayout>

        <!-- Date indicator -->
        <TextView
            android:id="@+id/tv_booking_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Thứ 2, ngày 20 Tháng 5"
            android:textColor="#59AE7B"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

        <!-- Branch / Store Info -->
        <TextView
            android:id="@+id/tv_booking_store"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Rootie Gò Vấp - 27 Quang Trung, P.10, Gò Vấp"
            android:textColor="#7E8A83"
            android:textSize="12sp"
            android:fontFamily="@font/be_vietnam_pro"
            android:drawableStart="@drawable/ic_home"
            android:drawablePadding="6dp"
            app:drawableTint="#95A192" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E8DA"
            android:layout_marginTop="12dp" />

        <!-- Customer details card container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@drawable/bg_rounded_white_card"
            android:backgroundTint="#F9FAF7">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN KHÁCH HÀNG"
                android:textColor="#95A192"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:fontFamily="@font/be_vietnam_pro" />

            <TextView
                android:id="@+id/tv_customer_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Nguyễn Khánh Xuân"
                android:textColor="#3E4D44"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro"
                android:drawableStart="@drawable/ic_customer"
                android:drawablePadding="8dp"
                app:drawableTint="#3E4D44" />

            <TextView
                android:id="@+id/tv_customer_phone_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="24dp"
                android:text="SĐT: 0123456789 | Email: xuannk@gmail.com"
                android:textColor="#7E8A83"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Note -->
            <TextView
                android:id="@+id/tv_booking_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="24dp"
                android:text="Ghi chú: Da nhạy cảm, dễ ửng đỏ."
                android:textColor="#C0392B"
                android:textSize="12sp"
                android:textStyle="italic"
                android:visibility="gone"
                android:fontFamily="@font/be_vietnam_pro"
                android:drawableStart="@drawable/ic_warning_triangle"
                android:drawablePadding="6dp"
                app:drawableTint="#C0392B" />

        </LinearLayout>

        <!-- Cancel Reason Area -->
        <LinearLayout
            android:id="@+id/ll_cancel_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@drawable/bg_rounded_white_card"
            android:backgroundTint="#FDF2F2"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LÝ DO HỦY LỊCH"
                android:textColor="#E74C3C"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:fontFamily="@font/be_vietnam_pro"
                android:drawableStart="@drawable/ic_close_circle"
                android:drawablePadding="6dp"
                app:drawableTint="#E74C3C" />

            <TextView
                android:id="@+id/tv_cancel_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="18dp"
                android:text="Khách không đến cuộc hẹn"
                android:textColor="#C0392B"
                android:textSize="13sp"
                android:fontFamily="@font/be_vietnam_pro" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E8DA"
            android:layout_marginTop="12dp" />

        <!-- Bottom Row: Status Badge and Actions -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_pill"
                android:backgroundTint="#FFEED6"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Chờ xác nhận"
                android:textColor="#FF9F1C"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Action Buttons -->
            <LinearLayout
                android:id="@+id/ll_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_nav_pill"
                    android:backgroundTint="#FADBD8"
                    android:text="Hủy"
                    android:textColor="#E74C3C"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:layout_marginEnd="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="16dp" />

                <Button
                    android:id="@+id/btn_action"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_nav_pill"
                    android:backgroundTint="#4F6544"
                    android:text="Xác nhận"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="16dp" />

            </LinearLayout>

        </RelativeLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
