<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <ImageView
        android:id="@+id/img_viewer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="24dp"
        android:contentDescription="Ảnh phóng to"
        android:scaleType="fitCenter" />

    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Đóng"
        android:padding="8dp"
        android:src="@drawable/ic_close_circle"
        app:tint="#FFFFFF" />

    <ImageView
        android:id="@+id/btn_prev"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Ảnh trước"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_back"
        android:visibility="gone"
        app:tint="#FFFFFF" />

    <ImageView
        android:id="@+id/btn_next"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Ảnh sau"
        android:padding="8dp"
        android:rotation="180"
        android:src="@drawable/ic_arrow_back"
        android:visibility="gone"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/txt_image_index"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/be_vietnam_pro"
        android:text="1/3"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:visibility="gone" />

</FrameLayout>
