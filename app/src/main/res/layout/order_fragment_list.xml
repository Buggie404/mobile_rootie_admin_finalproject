<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- Header Toolbar -->
    <RelativeLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo Icon "R" (Left) -->
        <ImageView
            android:id="@+id/img_logo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="Rootie Logo" />

        <!-- Title (Center) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Quản lý đơn hàng"
            android:textColor="#3E4D44"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

        <!-- Notification Button (Right) -->
        <FrameLayout
            android:id="@+id/btn_notification"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_notification"
                android:contentDescription="Thông báo" />

            <TextView
                android:id="@+id/notification_badge"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_notification_badge"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:textStyle="bold" />
        </FrameLayout>
    </RelativeLayout>

    <!-- Search Bar -->
    <LinearLayout
        android:id="@+id/layout_search"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_product_search_bar"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            app:tint="#7E8A83"
            android:contentDescription="Tìm kiếm" />

        <EditText
            android:id="@+id/edt_search"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:background="@android:color/transparent"
            android:hint="Tìm mã đơn..."
            android:textColor="#3E4D44"
            android:textColorHint="#97A49C"
            android:textSize="14sp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

    <!-- Filters & Sort -->
    <RelativeLayout
        android:id="@+id/layout_filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/layout_search"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Lọc button -->
        <LinearLayout
            android:id="@+id/btn_filter"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:background="@drawable/bg_tag_pill"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_filter"
                app:tint="#3E4D44"
                android:contentDescription="Lọc" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Lọc"
                android:textColor="#3E4D44"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>

        <!-- Sắp xếp button -->
        <LinearLayout
            android:id="@+id/btn_sort"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_tag_pill"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sắp xếp"
                android:textColor="#3E4D44"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_sort"
                app:tint="#3E4D44"
                android:contentDescription="Sắp xếp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Scrollable Status Tabs -->
    <HorizontalScrollView
        android:id="@+id/scroll_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layout_filters"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Tất cả tab -->
            <TextView
                android:id="@+id/tab_all"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/bg_nav_pill"
                android:backgroundTint="#2C3B2D"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="8dp"
                android:text="Tất cả (0)"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Chờ xác nhận tab -->
            <TextView
                android:id="@+id/tab_pending"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/bg_search_bar"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="8dp"
                android:text="Chờ xác nhận (0)"
                android:textColor="#3E4D44"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Đang chuẩn bị tab -->
            <TextView
                android:id="@+id/tab_preparing"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/bg_search_bar"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="8dp"
                android:text="Đang chuẩn bị (0)"
                android:textColor="#3E4D44"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Đang giao tab -->
            <TextView
                android:id="@+id/tab_delivering"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/bg_search_bar"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="8dp"
                android:text="Đang giao (0)"
                android:textColor="#3E4D44"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Hoàn tất tab -->
            <TextView
                android:id="@+id/tab_completed"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/bg_search_bar"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="8dp"
                android:text="Hoàn tất (0)"
                android:textColor="#3E4D44"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- Đã hủy tab -->
            <TextView
                android:id="@+id/tab_cancelled"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/bg_search_bar"
                android:gravity="center"
                android:text="Đã hủy (0)"
                android:textColor="#3E4D44"
                android:textSize="12sp"
                android:paddingHorizontal="14dp"
                android:fontFamily="@font/be_vietnam_pro" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Selection Row -->
    <RelativeLayout
        android:id="@+id/layout_selection_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/scroll_tabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layout_select_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_alignParentStart="true"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/img_select_all_checkbox"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_radio_primary_unchecked"
                android:contentDescription="Chọn tất cả" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Chọn tất cả"
                android:textColor="#3E4D44"
                android:textSize="14sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_selected_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Đã chọn: 0"
            android:textColor="#3E4D44"
            android:textSize="14sp"
            android:fontFamily="@font/be_vietnam_pro" />
    </RelativeLayout>

    <!-- Orders RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_orders"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/layout_selection_row"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/order_item" />

    <!-- Sticky Bulk Actions Bar -->
    <LinearLayout
        android:id="@+id/layout_bulk_actions"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:weightSum="2"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_bulk_cancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_order_btn_outline"
            app:backgroundTint="@null"
            android:text="Hủy (0)"
            android:textColor="#3E4D44"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

        <Button
            android:id="@+id/btn_bulk_approve"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_order_btn_solid"
            app:backgroundTint="@null"
            android:text="Xác nhận (0)"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
