<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp"
    android:gravity="start">

    <!-- Customer Avatar -->
    <androidx.cardview.widget.CardView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="bottom"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#E5E8DA">

        <ImageView
            android:id="@+id/img_msg_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/imv_avatar"
            android:scaleType="centerCrop" />
    </androidx.cardview.widget.CardView>

    <!-- Speech bubble -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="64dp"
        android:background="@drawable/bg_nav_pill"
        android:backgroundTint="#F2F4EB"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <TextView
            android:id="@+id/tv_msg_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customer message text"
            android:textColor="#3E4D44"
            android:textSize="14sp"
            android:fontFamily="@font/be_vietnam_pro" />

        <TextView
            android:id="@+id/tv_msg_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_gravity="end"
            android:text="10:30"
            android:textColor="#95A192"
            android:textSize="10sp"
            android:fontFamily="@font/be_vietnam_pro" />

    </LinearLayout>

</LinearLayout>
