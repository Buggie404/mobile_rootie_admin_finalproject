<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="4dp"
    android:paddingHorizontal="4dp">

    <!-- Incoming Message (Left Align) -->
    <LinearLayout
        android:id="@+id/layout_incoming"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:maxWidth="280dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/card_incoming_avatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <ImageView
                android:id="@+id/img_incoming_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/imv_avatar"
                android:contentDescription="Avatar" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_incoming_bubble"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/txt_incoming_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Incoming Message"
                android:textColor="#3E4D44"
                android:textSize="14sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>
    </LinearLayout>

    <!-- Outgoing Message (Right Align) -->
    <LinearLayout
        android:id="@+id/layout_outgoing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:background="@drawable/bg_outgoing_bubble"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:maxWidth="280dp">

        <TextView
            android:id="@+id/txt_outgoing_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Outgoing Message"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

</RelativeLayout>
