<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_header"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@android:color/transparent"
    android:elevation="0dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <!-- Avatar (Left) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/home_header_avatar_container"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardPreventCornerOverlap="true"
        app:cardBackgroundColor="@android:color/transparent">

        <ImageView
            android:id="@+id/home_header_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Avatar"
            android:scaleType="centerCrop"
            android:src="@drawable/imv_avatar" />
    </androidx.cardview.widget.CardView>

    <!-- Logo and Slogan Text (Middle) -->
    <ImageView
        android:id="@+id/home_header_logo_text"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/home_header_avatar_container"
        android:layout_marginStart="16dp"
        android:layout_centerVertical="true"
        android:adjustViewBounds="true"
        android:scaleType="fitStart"
        android:contentDescription="Rootie Logo Text"
        android:src="@drawable/imv_logo_text" />

    <!-- Message Button -->
    <FrameLayout
        android:id="@+id/home_header_message_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_toStartOf="@id/home_header_notification_btn"
        android:layout_centerVertical="true"
        android:layout_marginEnd="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:visibility="gone">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:contentDescription="Messages"
            android:src="@drawable/ic_message" />
    </FrameLayout>

    <!-- Notification Button (Right) -->
    <FrameLayout
        android:id="@+id/home_header_notification_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:background="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:contentDescription="Notifications"
            android:src="@drawable/ic_notification" />

        <!-- Badge -->
        <TextView
            android:id="@+id/home_header_notification_badge"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/ic_notification_badge"
            android:gravity="center"
            android:text=""
            android:textColor="@color/white"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

</RelativeLayout>
