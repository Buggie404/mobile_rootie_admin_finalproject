<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FEFBF4">

    <!-- 1. Header Toolbar -->
    <RelativeLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo Icon "R" (Left) -->
        <ImageView
            android:id="@+id/img_logo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="Rootie Logo" />

        <!-- Title -->
        <TextView
            android:id="@+id/txt_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/img_logo"
            android:layout_toStartOf="@id/btn_message"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="Quản lý khách hàng"
            android:textColor="#3E4D44"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

        <!-- Message Button -->
        <FrameLayout
            android:id="@+id/btn_message"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_toStartOf="@id/btn_notification"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_message"
                android:contentDescription="Tin nhắn" />

            <!-- Badge -->
            <TextView
                android:id="@+id/message_badge"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_message_badge"
                android:gravity="center"
                android:text=""
                android:textColor="@color/white"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Notification Button -->
        <FrameLayout
            android:id="@+id/btn_notification"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_notification"
                android:contentDescription="Thông báo" />

            <!-- Badge -->
            <TextView
                android:id="@+id/notification_badge"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/ic_notification_badge"
                android:gravity="center"
                android:text=""
                android:textColor="@color/white"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>

    </RelativeLayout>

    <View
        android:id="@+id/header_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E8DA"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header_divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="80dp">

            <!-- 2. Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_search_bar"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    app:tint="#8E998B" />

                <EditText
                    android:id="@+id/edt_search"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:background="@null"
                    android:hint="Tìm tên, SĐT..."
                    android:textColor="#3E4D44"
                    android:textColorHint="#8E998B"
                    android:textSize="14sp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:inputType="text"
                    android:maxLines="1" />

            </LinearLayout>

            <!-- 3. Tab Categories -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/tab_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <TextView
                        android:id="@+id/tab_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_nav_pill"
                        android:backgroundTint="#2C3B2D"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Tất cả"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/be_vietnam_pro" />

                    <TextView
                        android:id="@+id/tab_vip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_search_bar"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="VIP"
                        android:textColor="#3E4D44"
                        android:textSize="14sp"
                        android:fontFamily="@font/be_vietnam_pro" />

                    <TextView
                        android:id="@+id/tab_gold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_search_bar"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Vàng"
                        android:textColor="#3E4D44"
                        android:textSize="14sp"
                        android:fontFamily="@font/be_vietnam_pro" />

                    <TextView
                        android:id="@+id/tab_silver"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_search_bar"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Bạc"
                        android:textColor="#3E4D44"
                        android:textSize="14sp"
                        android:fontFamily="@font/be_vietnam_pro" />

                    <TextView
                        android:id="@+id/tab_normal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_search_bar"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Thường"
                        android:textColor="#3E4D44"
                        android:textSize="14sp"
                        android:fontFamily="@font/be_vietnam_pro" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- 4. Recycler View -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_customers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_customer" />

            <!-- 5. Footer Count -->
            <TextView
                android:id="@+id/txt_count_footer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="Hiển thị 5 / 248 khách hàng"
                android:textColor="#7E8A83"
                android:textSize="14sp"
                android:fontFamily="@font/be_vietnam_pro" />

            <!-- 6. Pagination Controls -->
            <LinearLayout
                android:id="@+id/pagination_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Previous Page Button -->
                <ImageView
                    android:id="@+id/btn_page_prev"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_search_bar"
                    android:contentDescription="Previous"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#3E4D44" />

                <!-- Page numbers -->
                <TextView
                    android:id="@+id/btn_page_1"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_nav_pill"
                    android:backgroundTint="#2C3B2D"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/be_vietnam_pro" />

                <TextView
                    android:id="@+id/btn_page_2"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_search_bar"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="#3E4D44"
                    android:textSize="14sp"
                    android:fontFamily="@font/be_vietnam_pro" />

                <TextView
                    android:id="@+id/btn_page_3"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_search_bar"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="#3E4D44"
                    android:textSize="14sp"
                    android:fontFamily="@font/be_vietnam_pro" />

                <!-- Next Page Button -->
                <ImageView
                    android:id="@+id/btn_page_next"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_search_bar"
                    android:contentDescription="Next"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="#3E4D44" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
