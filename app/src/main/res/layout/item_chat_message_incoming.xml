<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingTop="2dp"
    android:paddingEnd="56dp"
    android:paddingBottom="2dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_incoming_avatar"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="bottom"
        android:layout_marginEnd="8dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/img_incoming_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Avatar"
            android:scaleType="centerCrop"
            android:src="@drawable/imv_avatar" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/layout_incoming_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_incoming_bubble"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/txt_incoming_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro"
            android:lineSpacingExtra="2dp"
            android:maxWidth="260dp"
            android:text="Tin nhắn"
            android:textColor="#2F3D34"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txt_incoming_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="10:30"
            android:textColor="#6B776E"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
