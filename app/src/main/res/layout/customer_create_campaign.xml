<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FEFBF4">

    <!-- 1. Header Toolbar -->
    <RelativeLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FEFBF4"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#3E4D44" />

        <!-- Title -->
        <TextView
            android:id="@+id/txt_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btn_back"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:text="Tạo chương trình khuyến mãi"
            android:textColor="#3E4D44"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

    </RelativeLayout>

    <View
        android:id="@+id/header_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E8DA"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <!-- 2. Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header_divider"
        app:layout_constraintBottom_toTopOf="@id/bottom_buttons_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Section 1: Thông tin cơ bản -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin cơ bản"
                android:textColor="#3E4D44"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_white_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <!-- Tên chương trình -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tên chương trình"
                    android:textColor="#677559"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edt_campaign_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_search_bar"
                    android:backgroundTint="#FFFFFF"
                    android:hint="Nhập tên chương trình..."
                    android:textColorHint="#999999"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:inputType="text"
                    android:maxLines="1"
                    android:layout_marginBottom="16dp" />

                <!-- Mô tả -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mô tả"
                    android:textColor="#677559"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edt_campaign_desc"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_search_bar"
                    android:backgroundTint="#FFFFFF"
                    android:hint="Chi tiết chương trình loyalty..."
                    android:textColorHint="#999999"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:padding="16dp"
                    android:gravity="top|start"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:inputType="textMultiLine" />

            </LinearLayout>

            <!-- Section 2: Loại khuyến mãi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại khuyến mãi"
                android:textColor="#3E4D44"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro"
                android:layout_marginBottom="12dp" />

            <RadioGroup
                android:id="@+id/rg_campaign_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_rounded_white_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rad_type_discount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Khuyến mãi đơn hàng"
                    android:textColor="#3E4D44"
                    android:textSize="13sp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:checked="true"
                    android:buttonTint="#3E4D44" />

                <RadioButton
                    android:id="@+id/rad_type_free_ship"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Giảm giá phí giao hàng"
                    android:textColor="#3E4D44"
                    android:textSize="13sp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:buttonTint="#3E4D44" />

            </RadioGroup>

            <!-- Section 3: Sản phẩm áp dụng -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sản phẩm áp dụng"
                android:textColor="#3E4D44"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_white_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Danh mục sản phẩm"
                    android:textColor="#677559"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:layout_marginBottom="8dp" />

                <!-- Spinner styled like an input field -->
                <Spinner
                    android:id="@+id/spn_applicable_products"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_search_bar"
                    android:backgroundTint="#FFFFFF"
                    android:spinnerMode="dropdown"
                    android:paddingHorizontal="12dp" />

            </LinearLayout>

            <!-- Section 4: Điều kiện & Phần thưởng -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Điều kiện áp dụng"
                android:textColor="#3E4D44"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_white_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <!-- Tối thiểu đơn hàng -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tối thiểu đơn hàng (VNĐ)"
                    android:textColor="#677559"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:layout_marginBottom="8dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_search_bar"
                    android:backgroundTint="#FFFFFF"
                    android:layout_marginBottom="16dp">

                    <EditText
                        android:id="@+id/edt_min_order_value"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toStartOf="@id/txt_currency_unit"
                        android:background="@android:color/transparent"
                        android:hint="0"
                        android:textColorHint="#999999"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:inputType="number"
                        android:maxLines="1" />

                    <TextView
                        android:id="@+id/txt_currency_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_alignParentEnd="true"
                        android:gravity="center"
                        android:paddingEnd="16dp"
                        android:text="VNĐ"
                        android:textColor="#3E4D44"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro" />

                </RelativeLayout>

                <!-- Section: Phần thưởng -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E8DA"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phần thưởng"
                    android:textColor="#3E4D44"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Loại phần thưởng -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loại"
                            android:textColor="#677559"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:layout_marginBottom="6dp" />

                        <Spinner
                            android:id="@+id/spn_offer_type"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_search_bar"
                            android:backgroundTint="#FFFFFF"
                            android:spinnerMode="dropdown" />

                    </LinearLayout>

                    <!-- Giá trị phần thưởng -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.8"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:id="@+id/txt_discount_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giá trị (%)"
                            android:textColor="#677559"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/edt_discount_value"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_search_bar"
                            android:backgroundTint="#FFFFFF"
                            android:hint="10"
                            android:textColorHint="#999999"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:inputType="number"
                            android:maxLines="1" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Section 5: Thời gian hiệu lực -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thời gian hiệu lực"
                android:textColor="#3E4D44"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:background="@drawable/bg_rounded_white_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <!-- Ngày bắt đầu -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày bắt đầu"
                        android:textColor="#677559"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/edt_start_date"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_search_bar"
                        android:backgroundTint="#FFFFFF"
                        android:hint="dd/mm/yyyy"
                        android:textColorHint="#999999"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:focusable="false"
                        android:clickable="true"
                        android:fontFamily="@font/be_vietnam_pro" />

                </LinearLayout>

                <!-- Ngày kết thúc -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày kết thúc"
                        android:textColor="#677559"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/edt_end_date"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_search_bar"
                        android:backgroundTint="#FFFFFF"
                        android:hint="dd/mm/yyyy"
                        android:textColorHint="#999999"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:focusable="false"
                        android:clickable="true"
                        android:fontFamily="@font/be_vietnam_pro" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Buttons Container -->
    <LinearLayout
        android:id="@+id/bottom_buttons_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FEFBF4"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Huỷ -->
        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="0.8"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_search_bar"
            android:backgroundTint="#FFFFFF"
            android:textColor="#3E4D44"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:text="Huỷ"
            android:fontFamily="@font/be_vietnam_pro"
            android:clickable="true"
            android:focusable="true" />

        <!-- Tạo chương trình -->
        <TextView
            android:id="@+id/btn_save_campaign"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.2"
            android:background="@drawable/bg_nav_pill"
            android:backgroundTint="#2C3B2D"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:text="Tạo chương trình"
            android:fontFamily="@font/be_vietnam_pro"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
